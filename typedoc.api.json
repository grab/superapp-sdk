{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["./src/index.ts"],
  "plugin": [],
  "json": "./api-reference/api.json",
  "excludeExternals": true,
  "excludePrivate": true,
  "excludeInternal": true,
  "excludeProtected": true,
  "categorizeByGroup": true,
  "disableSources": true,
  "groupOrder": ["Documents", "Modules", "Type Guards", "Core", "Internals", "*"],
  "categoryOrder": [
    "Camera",
    "Checkout",
    "Container",
    "Device",
    "File",
    "Identity",
    "Locale",
    "Location",
    "Media",
    "Network",
    "Platform",
    "Profile",
    "Scope",
    "Splash Screen",
    "Storage",
    "System Web View Kit",
    "User Attributes",
    "*"
  ],
  "validation": {
    "notExported": true
  }
}
