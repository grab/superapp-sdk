{
  "name": "@grabjs/superapp-sdk",
  "version": "1.8.5",
  "description": "SDK for Grab SuperApp WebView.",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "scripts": {
    "lint": "eslint src --ext .js,.ts,.tsx",
    "build": "rm -rf dist && npm run build:cjs && npm run build:esm && npm run build:types",
    "build:cjs": "swc ./src -d dist/cjs --config-file .swcrc --strip-leading-paths",
    "build:esm": "swc ./src -d dist/esm --config-file .swcrc.esm --strip-leading-paths",
    "build:types": "tsc --emitDeclarationOnly --outDir dist/types",
    "prepublishOnly": "npm run build",
    "type-check": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grab/superapp-sdk.git"
  },
  "maintainers": [
    "Viet Hai Pham <viethai.pham@grabtaxi.com>",
    "Oleksandr Prokofiev <oleksandr.prokofiev@grabtaxi.com>",
    "Xijun Li <xijun.li@grabtaxi.com>"
  ],
  "files": [
    "dist",
    "docs"
  ],
  "keywords": [
    "superapp",
    "webview",
    "android",
    "ios"
  ],
  "author": "Viet Hai Pham <viethai.pham@grabtaxi.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/grab/superapp-sdk/issues"
  },
  "homepage": "https://github.com/grab/superapp-sdk#readme",
  "dependencies": {
    "@grabjs/mobile-kit-bridge-sdk": "^2.2.2",
    "crypto-js": "^4.2.0"
  },
  "devDependencies": {
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.13",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "typescript": "^5.9.3"
  }
}
