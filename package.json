{
  "name": "@grabjs/superapp-sdk",
  "version": "2.0.0-beta.1",
  "description": "SDK for Grab SuperApp WebView.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && rollup -c",
    "docs": "rm -rf docs && typedoc",
    "check": "npm run type:check && npm run format:check && npm run lint:check && npm run license:check",
    "fix": "npm run format:fix && npm run lint:fix && npm run license:fix",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "license:check": "tsx scripts/add-license-header.ts --check",
    "license:fix": "tsx scripts/add-license-header.ts",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "prepublishOnly": "npm run build",
    "type:check": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grab/superapp-sdk.git"
  },
  "maintainers": [
    "Viet Hai Pham <viethai.pham@grabtaxi.com>",
    "Oleksandr Prokofiev <oleksandr.prokofiev@grabtaxi.com>",
    "Xijun Li <xijun.li@grabtaxi.com>"
  ],
  "files": [
    "dist",
    "docs"
  ],
  "keywords": [
    "superapp",
    "webview",
    "android",
    "ios"
  ],
  "author": "Viet Hai Pham <viethai.pham@grabtaxi.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/grab/superapp-sdk/issues"
  },
  "homepage": "https://github.com/grab/superapp-sdk#readme",
  "dependencies": {
    "@grabjs/mobile-kit-bridge-sdk": "^2.2.2",
    "crypto-js": "^4.2.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^25.3.2",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^62.7.1",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "marked": "^12.0.2",
    "prettier": "^3.8.1",
    "rollup": "^4.59.0",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "src/**/*.{ts,js}": [
      "tsx scripts/add-license-header.ts",
      "sh -c 'prettier --write \"$@\" && eslint --fix \"$@\"' _"
    ],
    "scripts/**/*.{ts,js}": [
      "tsx scripts/add-license-header.ts",
      "sh -c 'prettier --write \"$@\" && eslint --fix \"$@\"' _"
    ],
    "*.config.{js,mjs,cjs}": [
      "prettier --write"
    ],
    ".prettierrc": [
      "prettier --write"
    ]
  }
}
