{
  "name": "@grabjs/superapp-sdk",
  "version": "2.0.0-beta.1",
  "description": "SDK for Grab SuperApp WebView.",
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "format:check": "prettier --check \"src/**/*.{ts,js}\"",
    "format:fix": "prettier --write \"src/**/*.{ts,js}\"",
    "lint:check": "eslint src",
    "lint:fix": "eslint src --fix",
    "build": "rm -rf dist && npm run build:esm && npm run build:types && npm run build:browser",
    "build:esm": "swc ./src -d dist/esm --config-file .swcrc.esm --strip-leading-paths",
    "build:types": "tsc --emitDeclarationOnly --outDir dist/types",
    "build:browser": "rollup -c",
    "prepublishOnly": "npm run build",
    "type-check": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grab/superapp-sdk.git"
  },
  "maintainers": [
    "Viet Hai Pham <viethai.pham@grabtaxi.com>",
    "Oleksandr Prokofiev <oleksandr.prokofiev@grabtaxi.com>",
    "Xijun Li <xijun.li@grabtaxi.com>"
  ],
  "files": [
    "dist",
    "docs"
  ],
  "keywords": [
    "superapp",
    "webview",
    "android",
    "ios"
  ],
  "author": "Viet Hai Pham <viethai.pham@grabtaxi.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/grab/superapp-sdk/issues"
  },
  "homepage": "https://github.com/grab/superapp-sdk#readme",
  "dependencies": {
    "@grabjs/mobile-kit-bridge-sdk": "^2.2.2",
    "crypto-js": "^4.2.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.13",
    "@types/crypto-js": "^4.2.2",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "rollup": "^4.59.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  }
}
