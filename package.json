{
  "name": "@grabjs/superapp-sdk",
  "version": "2.0.0-beta.2",
  "description": "SDK for Grab SuperApp WebView.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "typings": "dist/index.d.ts",
  "sideEffects": false,
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist docs",
    "build": "rimraf build && rimraf dist && rollup -c && mkdir dist && cp build/index.js dist/index.js && cp build/index.esm.js dist/index.esm.js && api-extractor run --local --verbose && tsx scripts/print-bundle-size.ts",
    "build:analyze": "rimraf dist && ROLLUP_VISUALIZE=1 rollup -c",
    "docs": "rimraf docs && typedoc",
    "fix": "npm run format:fix && npm run lint:fix && npm run license:fix",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "check": "npm run type:check && npm run format:check && npm run lint:check && npm run license:check && npm run audit:check && npm run docs && git diff --exit-code docs/",
    "audit:check": "npm audit --audit-level=critical",
    "license:check": "tsx scripts/add-license-header.ts --check src scripts rollup.config.mjs eslint.config.js",
    "license:fix": "tsx scripts/add-license-header.ts src scripts rollup.config.mjs eslint.config.js",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:staged": "lint-staged",
    "prepare": "husky",
    "prepublishOnly": "npm run build",
    "type:check": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grab/superapp-sdk.git"
  },
  "maintainers": [
    "Viet Hai Pham <viethai.pham@grabtaxi.com>",
    "Oleksandr Prokofiev <oleksandr.prokofiev@grabtaxi.com>",
    "Xijun Li <xijun.li@grabtaxi.com>"
  ],
  "files": [
    "dist"
  ],
  "keywords": [
    "superapp",
    "webview",
    "android",
    "ios"
  ],
  "author": "Viet Hai Pham <viethai.pham@grabtaxi.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/grab/superapp-sdk/issues"
  },
  "homepage": "https://github.com/grab/superapp-sdk#readme",
  "devDependencies": {
    "@grabjs/mobile-kit-bridge-sdk": "^2.2.2",
    "@microsoft/api-extractor": "^7.57.6",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "@types/node@^20",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^62.7.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.59.0",
    "rollup-plugin-visualizer": "^7.0.0",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "src/**/*.{ts,js}": [
      "tsx scripts/add-license-header.ts",
      "prettier --write",
      "eslint --fix --max-warnings 0"
    ],
    "scripts/**/*.{ts,js}": [
      "tsx scripts/add-license-header.ts",
      "prettier --write",
      "eslint --fix --max-warnings 0"
    ],
    "*.config.{js,mjs,cjs}": [
      "tsx scripts/add-license-header.ts",
      "prettier --write",
      "eslint --fix --max-warnings 0"
    ],
    "**/*.json": [
      "prettier --write"
    ],
    ".prettierrc": [
      "prettier --write"
    ],
    "*.{md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
