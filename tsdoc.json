{
  "$schema": "https://developer.microsoft.com/json-schemas/tsdoc/v0/tsdoc.schema.json",
  "extends": ["@microsoft/api-extractor/extends/tsdoc-base.json"],
  "tagDefinitions": [
    {
      "tagName": "@group",
      "syntaxKind": "block",
      "allowMultiple": true
    },
    {
      "tagName": "@noInheritDoc",
      "syntaxKind": "block",
      "allowMultiple": false
    },
    {
      "tagName": "@hidden",
      "syntaxKind": "block",
      "allowMultiple": false
    },
    {
      "tagName": "@protected",
      "syntaxKind": "block",
      "allowMultiple": false
    },
    {
      "tagName": "@private",
      "syntaxKind": "block",
      "allowMultiple": false
    },
    {
      "tagName": "@requiredOAuthScope",
      "syntaxKind": "block",
      "allowMultiple": false
    },
    {
      "tagName": "@minimumGrabAppVersion",
      "syntaxKind": "block",
      "allowMultiple": false
    }
  ],
  "supportForTags": {
    "@group": true,
    "@noInheritDoc": true,
    "@hidden": true,
    "@protected": true,
    "@private": true,
    "@requiredOAuthScope": true,
    "@minimumGrabAppVersion": true
  }
}
