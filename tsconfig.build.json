{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2018", "DOM"],
    "target": "ES2018",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationDir": "dist/types",
    "outDir": "dist/types"
  },
  "include": ["src/**/*"],
  "exclude": ["src/**/*.test.ts", "src/**/*.spec.ts", "dist"]
} 