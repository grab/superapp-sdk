{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["./src/index.ts"],
  "plugin": ["typedoc-plugin-markdown", "typedoc-plugin-valibot"],
  "out": "./md",
  "readme": "README.md",
  "excludeExternals": true,
  "excludePrivate": true,
  "excludeInternal": true,
  "excludeProtected": true,
  "categorizeByGroup": true,
  "disableSources": true,
  "hidePageHeader": true,
  "hidePageTitle": false,
  "hideBreadcrumbs": false,
  "expandObjects": true,
  "expandParameters": true,
  "parametersFormat": "list",
  "projectDocuments": ["./guides/setup.md", "./guides/integration.md"],
  "validation": {
    "notExported": true
  }
}
