{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["./src/index.ts"],
  "plugin": ["typedoc-plugin-markdown"],
  "out": "./md",
  "readme": "README.md",
  "excludeExternals": true,
  "excludePrivate": true,
  "excludeInternal": true,
  "excludeProtected": true,
  "categorizeByGroup": true,
  "disableSources": true,
  "groupOrder": ["Documents", "Modules", "Type Guards", "Core", "*"],
  "categoryOrder": [
    "Camera",
    "Checkout",
    "Container",
    "Device",
    "File",
    "Identity",
    "Locale",
    "Location",
    "Media",
    "Network",
    "Platform",
    "Profile",
    "Scope",
    "Splash Screen",
    "Storage",
    "System Web View Kit",
    "User Attributes",
    "*"
  ],
  "hidePageHeader": true,
  "hidePageTitle": false,
  "hideBreadcrumbs": false,
  "expandObjects": true,
  "expandParameters": true,
  "parametersFormat": "list",
  "projectDocuments": ["./guides/setup.md", "./guides/concepts.md", "./guides/integration.md"],
  "validation": {
    "notExported": true
  }
}
